{
  "name": "silence-platform-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "cross-env SASS_SILENCE_DEPRECATIONS=legacy-js-api vite",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 SASS_SILENCE_DEPRECATIONS=legacy-js-api vue-tsc --skipLibCheck --noEmit && cross-env NODE_OPTIONS=--max-old-space-size=4096 SASS_SILENCE_DEPRECATIONS=legacy-js-api vite build",
    "build:no-check": "cross-env NODE_OPTIONS=--max-old-space-size=4096 SASS_SILENCE_DEPRECATIONS=legacy-js-api vite build",
    "build:fast": "cross-env NODE_OPTIONS=--max-old-space-size=4096 SASS_SILENCE_DEPRECATIONS=legacy-js-api vite build",
    "preview": "cross-env SASS_SILENCE_DEPRECATIONS=legacy-js-api vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@iconify/vue": "^5.0.0",
    "@monaco-editor/loader": "^1.5.0",
    "@vueuse/core": "^13.0.0",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.13.6",
    "defu": "^6.1.4",
    "diff": "^8.0.3",
    "echarts": "^5.6.0",
    "moment": "^2.30.1",
    "monaco-editor": "^0.52.2",
    "naive-ui": "^2.43.2",
    "pinia": "^2.1.6",
    "ts-md5": "^1.3.1",
    "uuid": "^11.1.0",
    "vue": "^3.3.4",
    "vue-echarts": "^7.0.3",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.5.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-typescript": "^14.5.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.25.1",
    "eslint-plugin-vue": "^10.0.0",
    "less": "^4.2.2",
    "lightningcss": "^1.30.2",
    "sass": "^1.86.0",
    "sass-embedded": "^1.93.2",
    "typescript": "^5.2.2",
    "vite": "^8.0.0",
    "vue-tsc": "^2.0.0"
  }
}
